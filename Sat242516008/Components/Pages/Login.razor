
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@page "/login"
@using MyDbModels
@using Providers
@using Services
@inject NavigationManager Nav
@inject IMyDbModel_Provider Provider
@inject AuthService AuthService

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 400px; border-radius: 15px;">
        <div class="card-header bg-dark text-white text-center p-4">
            <div class="mb-2">
                <i class="bi bi-shield-lock-fill" style="font-size: 2.5rem;"></i>
            </div>
            <h4 class="fw-bold">Kalite Sistem Girişi</h4>
        </div>
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Kullanıcı Adı</label>
                <input type="text" class="form-control" @bind="LoginUser.Username" placeholder="admin" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Şifre</label>
                <input type="password" class="form-control" @bind="LoginUser.PasswordHash" placeholder="123456" />
            </div>

            <button class="btn btn-primary w-100 py-2 shadow fw-bold" @onclick="HandleLogin" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Giriş Yap
            </button>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger mt-3 small text-center">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> @ErrorMessage
                </div>
            }
        </div>
    </div>
</div>

@code {
    private User LoginUser = new();
    private string ErrorMessage = "";
    private bool IsLoading = false;

    private async Task HandleLogin()
    {
        var inputUser = LoginUser.Username?.Trim();
        var inputPass = LoginUser.PasswordHash?.Trim();

        if (string.IsNullOrEmpty(inputUser) || string.IsNullOrEmpty(inputPass))
        {
            ErrorMessage = "Lütfen alanları doldurun.";
            return;
        }

        try
        {
            IsLoading = true;
            ErrorMessage = "";
            StateHasChanged();

            // SQL'den verileri çekiyoruz
            var result = await Provider.GetItems<User>("SELECT * FROM Users");

            // EĞER VERİTABANI BOŞSA: Test sürecini aksatmamak için geçici bir kontrol
            if (result == null || !result.Any())
            {
                if (inputUser == "admin" && inputPass == "123456")
                {
                    // Veritabanı boş olsa bile admin girişi yaptır (Failsafe)
                    var mockUser = new User { Username = "admin", FullName = "Geçici Yönetici", Role = "Admin" };
                    AuthService.Login(mockUser);
                    Nav.NavigateTo("/products", forceLoad: true);
                    return;
                }
                ErrorMessage = "Veritabanında kayıtlı kullanıcı bulunamadı.";
                return;
            }

            // Normal Veritabanı Kontrolü
            var user = result.FirstOrDefault(u =>
                u.Username.Equals(inputUser, StringComparison.OrdinalIgnoreCase) &&
                u.PasswordHash == inputPass &&
                u.IsActive == 1);

            if (user != null)
            {
                AuthService.Login(user);
                Nav.NavigateTo("/products", forceLoad: true);
            }
            else
            {
                ErrorMessage = "Hatalı kullanıcı adı veya şifre.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Sistem Hatası: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }
}