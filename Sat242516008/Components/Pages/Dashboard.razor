@page "/dashboard"
@using MyDbModels
@using Providers
@rendermode InteractiveServer
@inject IMyDbModel_Provider Provider

<PageTitle>İstatistikler</PageTitle>

<div class="container mt-4">
    <h3><i class="bi bi-graph-up"></i> Sistem İstatistikleri</h3>
    <hr />

    <div class="row">
        @if (Stats == null)
        {
            <p>Veriler analiz ediliyor...</p>
        }
        else
        {
            @foreach (var stat in Stats)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-body text-center">
                            <h6 class="text-muted text-uppercase small fw-bold">@stat.Key İşlemleri</h6>
                            <h2 class="display-6 @GetColorClass(stat.Key)">@stat.Value</h2>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @* Basit Bir Görselleştirme (CSS ile Bar Chart) *@
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-white fw-bold">İşlem Yoğunluğu Grafiği</div>
        <div class="card-body">
            <div class="d-flex align-items-end justify-content-around" style="height: 200px;">
                @foreach (var stat in Stats)
                {
                    <div class="text-center">
                        <div class="@GetColorClass(stat.Key) opacity-75"
                             style="width: 60px; height: @(int.Parse(stat.Value) * 20)px; border-radius: 5px 5px 0 0;">
                        </div>
                        <div class="small mt-2">@stat.Key</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IEnumerable<MyDbModel_Result_KeyValue<string, string>> Stats { get; set; } = new List<MyDbModel_Result_KeyValue<string, string>>();

    protected override async Task OnInitializedAsync()
    {
        // Daha önce oluşturduğumuz Result_KeyValue yapısını kullanarak veriyi çekiyoruz
        Stats = await Provider.GetItems<MyDbModel_Result_KeyValue<string, string>>("sp_GetLogStatistics");
    }

    private string GetColorClass(string? type) => type switch
    {
        "INSERT" => "text-success bg-success",
        "UPDATE" => "text-warning bg-warning",
        "DELETE" => "text-danger bg-danger",
        _ => "text-primary bg-primary"
    };
}